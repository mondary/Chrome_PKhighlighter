{
  "manifest_version": 3,
  "name": "PKhighlighter",
  "version": "0.4.0",
  "description": "Highlight keywords with colors and strike-through excluded terms, per site.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon2.png"
  },
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon2.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["keyword-highlighter.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage"]
}
